# ================================================
# infra/.env.example — HumaNai Local Environment
# Copy this to .env and fill in all CHANGE_ME values
# ================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=humanai_db
POSTGRES_USER=humanai_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DATABASE_URL=postgresql+asyncpg://humanai_user:CHANGE_ME@localhost:5432/humanai_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=humanai_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET_DOCUMENTS=humanai-documents
MINIO_BUCKET_RAG=humanai-rag-sources

# --- Firebase ---
FIREBASE_PROJECT_ID=humanai-ydays-2026
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/service-account.json

# --- Encryption ---
APP_ENCRYPTION_KEY=CHANGE_ME_32_chars_minimum_key!!

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Monitoring ---
GRAFANA_PASSWORD=CHANGE_ME_grafana

# --- n8n ---
N8N_ENCRYPTION_KEY=CHANGE_ME_32_chars_n8n_key_here!!
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n

# --- LLM (via n8n → OpenRouter) ---
# Get your free key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Internal API Token (shared secret: backend ↔ n8n) ---
# Must match INTERNAL_API_TOKEN in humanai_backend/.env
INTERNAL_API_TOKEN=CHANGE_ME_internal_token_32chars!!

# --- n8n Webhook URLs (used by the FastAPI backend to call n8n) ---
# When running locally (backend outside Docker): use localhost
N8N_WEBHOOK_URL_ASSISTANT=http://localhost:5678/webhook/assistant
N8N_WEBHOOK_URL_DOC_GEN=http://localhost:5678/webhook/doc-gen
# When running backend inside Docker (same network): use container name
# N8N_WEBHOOK_URL_ASSISTANT=http://humanai_n8n:5678/webhook/assistant
# N8N_WEBHOOK_URL_DOC_GEN=http://humanai_n8n:5678/webhook/doc-gen
