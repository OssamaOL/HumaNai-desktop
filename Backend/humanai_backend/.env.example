# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=humanai_db
POSTGRES_USER=humanai_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://humanai_user:CHANGE_ME@localhost:5432/humanai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_PROJECT_ID=humanai-ydays-2026
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/service-account.json

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=humanai_minio
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_DOCUMENTS=humanai-documents
MINIO_BUCKET_RAG=humanai-rag-sources
MINIO_SECURE=false

# Encryption
APP_ENCRYPTION_KEY=CHANGE_ME_32_chars_exactly_here!!

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-sonnet-4-20250514

# OpenRouter / Agent IA
OPENROUTER_API_KEY=sk-or-CHANGE_ME
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct
AI_MAX_OUTPUT_TOKENS=2000
AI_TIMEOUT_SECONDS=120

# App
APP_ENV=development
APP_VERSION=1.0.0
